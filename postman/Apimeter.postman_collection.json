{
  "info": {
    "_postman_id": "8ee8d137-4e20-4abd-a044-0988f1ef1f91",
    "name": "Apimeter API",
    "description": "Postman collection for testing the Apimeter backend locally. Import this collection and the Apimeter Local environment, then run requests from top to bottom.",
